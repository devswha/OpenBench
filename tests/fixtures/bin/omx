#!/usr/bin/env python3
from pathlib import Path
import sys

from agent_task_logic import apply_task, extract_task_id

if "--version" in sys.argv or "version" in sys.argv:
    print("oh-my-codex v0.0-test")
    raise SystemExit(0)

cwd = Path.cwd()
if "-C" in sys.argv:
    try:
        cwd = Path(sys.argv[sys.argv.index("-C") + 1])
    except IndexError as exc:
        raise SystemExit("missing directory after -C") from exc

prompt = sys.argv[-1] if len(sys.argv) > 1 else ""
task_id = extract_task_id(prompt)
if task_id:
    apply_task(task_id, cwd)
    print(f"applied task {task_id}")
    raise SystemExit(0)

print("fake omx invocation")
raise SystemExit(0)
